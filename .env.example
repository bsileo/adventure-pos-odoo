# Copy to `.env` and fill in. Never commit `.env`.
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

ODOO_VERSION=19.0
POSTGRES_DB=odoo
POSTGRES_USER=odoo
# Local dev only; use a strong value outside your machine.
POSTGRES_PASSWORD=change_me_local_dev
# Postgres binds to localhost by default, which is safer for remote VMs.
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432
ODOO_PORT=8069
