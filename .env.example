# Copy to `.env` and fill in. Never commit `.env`.
# Use Unix (LF) line endings for `.env` if you use WSL or bash scripts; CRLF can break docker/env.
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

ODOO_VERSION=19.0
POSTGRES_DB=odoo
POSTGRES_USER=odoo
# Local dev only; use a strong value outside your machine.
POSTGRES_PASSWORD=change_me_local_dev
# Postgres binds to localhost by default, which is safer for remote VMs.
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432
# Optional: Docker named volume for Postgres files (default: adventurepos-sandbox-postgres).
# Shared GCP sandbox: leave unset so data keeps the same volume across VM reboots and deploys.
# Local: set a unique name per clone if you run several copies on one Docker host.
# POSTGRES_VOLUME_NAME=adventurepos-local-pg
ODOO_PORT=8069
