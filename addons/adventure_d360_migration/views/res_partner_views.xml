<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_d360_history_archive" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.d360.history.archive</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_history_archive_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-archive"
                        groups="base.group_system"
                        invisible="history_archive_order_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="history_archive_order_count"/>
                        </span>
                        <span class="o_stat_text">D360 History</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
